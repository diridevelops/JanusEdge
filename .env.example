# Copy this file to .env before running Docker Compose.

# MinIO root account used by the MinIO service itself.
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Backend application settings.
FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
MONGO_URI=mongodb://mongo:27017/tradelogs
JWT_SECRET_KEY=dev-jwt-secret-change-in-production
SECRET_KEY=dev-secret-change-in-production
CORS_ORIGINS=http://localhost:5173
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=tradelogs-media
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000

# Frontend development settings.
VITE_API_BASE_URL=/api
VITE_API_PROXY_TARGET=http://backend:5000
VITE_APP_NAME=TradeLogs